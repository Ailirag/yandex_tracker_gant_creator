# Учётные данные Яндекс Трекера. Скопируйте в .env ИЛИ задайте как
# переменные окружения (приоритетнее). НЕ коммитьте реальный .env.
#
# Вариант через переменные окружения (рекомендуется):
#   YATRACKER_TOKEN_GT=<OAuth-токен>
#   YATRACKER_ORGID_GT=<ID организации Яндекс 360>
#
# Вариант через файл .env (в корне проекта, см. config.ENV_FILE):
token = <OAuth-токен>
org_id = <ID организации Яндекс 360>
