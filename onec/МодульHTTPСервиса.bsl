// Модуль HTTP-сервиса «ПланировщикЗадач».
// Обработчики: КапаситиGET (график доступности групп), ПланPOST (приём расчёта).

#Область ОбработчикиСервиса

Функция КапаситиGET(Запрос)

	НачалоПериода = ДатаИзПараметра(Запрос, "from");
	ОкончаниеПериода = ДатаИзПараметра(Запрос, "to");
	Если НачалоПериода = '00010101' Или ОкончаниеПериода = '00010101' Тогда
		Возврат ОтветОшибка(400, "Ожидаются параметры from и to в формате YYYY-MM-DD");
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("from", Формат(НачалоПериода, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("to", Формат(ОкончаниеПериода, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("groups", ДоступностьГруппПоДням(НачалоПериода, ОкончаниеПериода));

	Возврат ОтветJSON(200, Результат);

КонецФункции

Функция ПланPOST(Запрос)

	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(Запрос.ПолучитьТелоКакСтроку());
	Элементы = ПрочитатьJSON(Чтение, Ложь);

	Принято = 0;
	НеНайдены = Новый Массив;
	ДатаРасчета = ТекущаяДатаСеанса();

	Для Каждого Элемент Из Элементы Цикл
		Задача = Справочники.Задачи.НайтиПоКоду(Элемент.key);
		Если Задача.Пустая() Тогда
			Задача = Справочники.Задачи.НайтиПоНаименованию(Элемент.key, Истина);
		КонецЕсли;
		Если Задача.Пустая() Тогда
			НеНайдены.Добавить(Элемент.key);
			Продолжить;
		КонецЕсли;

		НаборЗаписей = РегистрыСведений.РассчитанныйПланЗадач.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Задача.Установить(Задача);
		НаборЗаписей.Отбор.ДатаРасчета.Установить(ДатаРасчета);
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Задача = Задача;
		НоваяЗапись.ДатаРасчета = ДатаРасчета;
		НоваяЗапись.ДатаНачала = ДатаИзСтроки(Элемент, "new_start");
		НоваяЗапись.ДатаОкончания = ДатаИзСтроки(Элемент, "new_end");
		НоваяЗапись.ПлановаяДатаЗавершения = ДатаИзСтроки(Элемент, "new_planned_completion");
		НоваяЗапись.ИсточникРасчета = "planner-cli";
		Если Элемент.Свойство("warnings") И Элемент.warnings <> Неопределено Тогда
			НоваяЗапись.Предупреждения = СтрСоединить(Элемент.warnings, "; ");
		КонецЕсли;
		НаборЗаписей.Записать(Истина);
		Принято = Принято + 1;
	КонецЦикла;

	Ответ = Новый Структура("accepted, not_found", Принято, НеНайдены);
	Возврат ОтветJSON(200, Ответ);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Доступность ресурса по группам-родителям за период: соответствие
// "Имя группы" -> Соответствие "yyyy-MM-dd" -> FTE.
// Запрос повторяет обработку «ГрафикДоступностиРесурса»: остатки и обороты
// РН ДоступностьРесурса по дням производственного календаря, итог по родителю.
Функция ДоступностьГруппПоДням(НачалоПериода, ОкончаниеПериода)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(НачалоПериода));
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецДня(ОкончаниеПериода));
	Запрос.УстановитьПараметр("Сотрудники", ГруппыВерхнегоУровня());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеПроизводственногоКалендаря.Дата КАК Дата
	|ПОМЕСТИТЬ ВТ_Дни
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|;
	|ВЫБРАТЬ
	|	Дни.Дата КАК Дата,
	|	ДоступностьРесурсаОстаткиИОбороты.Сотрудник КАК Сотрудник,
	|	СУММА(ВЫБОР
	|			КОГДА ДоступностьРесурсаОстаткиИОбороты.Период = &НачалоПериода
	|				ТОГДА ДоступностьРесурсаОстаткиИОбороты.ДоступныйРесурсКонечныйОстаток
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ДоступностьРесурсаОстаткиИОбороты.Период <= Дни.Дата
	|						ТОГДА ДоступностьРесурсаОстаткиИОбороты.ДоступныйРесурсОборот
	|					ИНАЧЕ 0
	|				КОНЕЦ
	|		КОНЕЦ) КАК ДоступныйРесурс
	|ПОМЕСТИТЬ ВТ_Итог
	|ИЗ
	|	ВТ_Дни КАК Дни,
	|	РегистрНакопления.ДоступностьРесурса.ОстаткиИОбороты(, , День, , Сотрудник В ИЕРАРХИИ (&Сотрудники)) КАК ДоступностьРесурсаОстаткиИОбороты
	|СГРУППИРОВАТЬ ПО
	|	Дни.Дата,
	|	ДоступностьРесурсаОстаткиИОбороты.Сотрудник
	|;
	|ВЫБРАТЬ
	|	ВТ_Итог.Дата КАК Дата,
	|	ВТ_Итог.Сотрудник.Родитель КАК Группа,
	|	СУММА(ВЫБОР
	|			КОГДА ВТ_Итог.ДоступныйРесурс < 0
	|				ТОГДА 0
	|			ИНАЧЕ ВТ_Итог.ДоступныйРесурс
	|		КОНЕЦ) КАК ДоступныйРесурс
	|ИЗ
	|	ВТ_Итог КАК ВТ_Итог
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Итог.Дата,
	|	ВТ_Итог.Сотрудник.Родитель";

	Группы = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Не ЗначениеЗаполнено(Выборка.Группа) Или Выборка.ДоступныйРесурс = 0 Тогда
			Продолжить;
		КонецЕсли;
		ИмяГруппы = Строка(Выборка.Группа.Наименование);
		ДниГруппы = Группы.Получить(ИмяГруппы);
		Если ДниГруппы = Неопределено Тогда
			ДниГруппы = Новый Соответствие;
			Группы.Вставить(ИмяГруппы, ДниГруппы);
		КонецЕсли;
		ДниГруппы.Вставить(Формат(Выборка.Дата, "ДФ=yyyy-MM-dd"), Выборка.ДоступныйРесурс);
	КонецЦикла;

	Возврат Группы;

КонецФункции

// Все группы верхнего уровня справочника Сотрудники (планировщик сам
// выбирает нужные по конфигурации команд).
Функция ГруппыВерхнегоУровня()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ЭтоГруппа
	|	И НЕ Сотрудники.ПометкаУдаления");

	Группы = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Группы.Добавить(Выборка.Ссылка);
	КонецЦикла;
	Возврат Группы;

КонецФункции

Функция ДатаИзПараметра(Запрос, Имя)

	Значение = Запрос.ПараметрыЗапроса.Получить(Имя);
	Если Значение = Неопределено Тогда
		Возврат '00010101';
	КонецЕсли;
	Возврат ДатаИзISO(Значение);

КонецФункции

Функция ДатаИзСтроки(Элемент, Имя)

	Значение = Неопределено;
	Если Не Элемент.Свойство(Имя, Значение) Или Значение = Неопределено Тогда
		Возврат '00010101';
	КонецЕсли;
	Возврат ДатаИзISO(Значение);

КонецФункции

Функция ДатаИзISO(Строка)

	// "2026-07-15" -> 20260715
	Попытка
		Возврат Дата(СтрЗаменить(Сокр(Строка), "-", ""));
	Исключение
		Возврат '00010101';
	КонецПопытки;

КонецФункции

Функция ОтветJSON(КодСостояния, Данные)

	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто));
	ЗаписатьJSON(Запись, Данные);

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(Запись.Закрыть());
	Возврат Ответ;

КонецФункции

Функция ОтветОшибка(КодСостояния, Текст)

	Возврат ОтветJSON(КодСостояния, Новый Структура("error", Текст));

КонецФункции

#КонецОбласти
